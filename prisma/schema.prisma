// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  USER
  SUPERVISOR
}

model User {
  id          Int       @id @default(autoincrement())
  email       String    @unique
  name        String
  password    String
  role        Role      @default(USER)
  capturas    Destajo[]
}

model Destajista {
  id          Int       @id @default(autoincrement())
  nombre      String
  status      Boolean   @default(true)
  destajos    Destajo[]
}

model Mz {
  id          Int       @id @default(autoincrement())
  nombre      String
  lotes       Lote[]
}

model Lote {
  id          Int       @id @default(autoincrement())
  numero      String
  mzId        Int
  mz          Mz        @relation(fields: [mzId], references: [id])
  destajos    Destajo[]
}

model Destajo {
  id             Int        @id @default(autoincrement())
  fecha          DateTime   @default(now())
  cantidad       Float
  destajistaId   Int
  destajista     Destajista @relation(fields: [destajistaId], references: [id])
  loteId         Int
  lote           Lote       @relation(fields: [loteId], references: [id])
  capturadoPorId Int
  capturadoPor   User       @relation(fields: [capturadoPorId], references: [id])
}
